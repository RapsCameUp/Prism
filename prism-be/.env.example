NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string
DATABASE_URL=MongoDBCONNECTION_HERE.mongodb.net/prism?retryWrites=true&w=majority

# JWT
JWT_SECRET=YOUR_KEY

# Redis
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379

# Gemini AI
GEMINI_API_KEY=GEMINI_API_KEY

# GitHub
GITHUB_TOKEN=ghp_your_github_token_here

# Splunk MCP
SPLUNK_MCP_ENDPOINT=https://localhost:8089/services/mcp
SPLUNK_MCP_TOKEN=SPLUNK_MCP_TOKEN

# Splunk Direct (optional)
SPLUNK_BASE_URL=https://localhost:8089
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=changeme

# Client
CLIENT_URL=http://localhost:5173

CDTSM_BASE_URL=http://localhost:8080
CDTSM_AUTH_TOKEN=CDTSM_AUTH_TOKEN
PREDICTION_ENABLED=true
PREDICTION_INTERVAL_MINUTES=10
